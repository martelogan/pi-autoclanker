{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "pi-autoclanker config",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "autoclankerBinary",
    "sessionRoot",
    "defaultIdeasMode"
  ],
  "properties": {
    "autoclankerBinary": {
      "type": "string",
      "minLength": 1
    },
    "sessionRoot": {
      "type": "string",
      "minLength": 1
    },
    "defaultIdeasMode": {
      "type": "string",
      "enum": ["rough", "canonicalize", "advanced_json"]
    },
    "autoclankerRepo": {
      "type": "string",
      "minLength": 1
    },
    "allowBilledLive": {
      "type": "boolean"
    },
    "goal": {
      "type": "string",
      "minLength": 1
    },
    "evalCommand": {
      "type": "string",
      "minLength": 1
    },
    "constraints": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "enabled": {
      "type": "boolean"
    }
  }
}
