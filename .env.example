# Local developer overrides for pi-autoclanker.
# Copy to .env.local and fill only the values you actually use.

# Opt-in live lanes
PI_AUTOCLANKER_RUN_UPSTREAM_LIVE=0
PI_AUTOCLANKER_RUN_BILLED_LIVE=0

# Optional autoclanker resolution overrides
# PI_AUTOCLANKER_AUTOCLANKER_BINARY=autoclanker
# PI_AUTOCLANKER_AUTOCLANKER_REPO=/absolute/path/to/autoclanker

# Optional runtime/provider selection
# PI_AUTOCLANKER_CANONICALIZATION_MODEL=anthropic
# PI_AUTOCLANKER_PYTHON=python3
# PI_AUTOCLANKER_PY_ORACLE_REPO=/absolute/path/to/pi-autoclanker-python

# Provider auth used by billed live canonicalization
# ANTHROPIC_API_KEY=
# AUTOCLANKER_ANTHROPIC_API_KEY=
