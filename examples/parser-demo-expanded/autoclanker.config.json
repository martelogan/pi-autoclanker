{
  "allowBilledLive": false,
  "autoclankerBinary": "autoclanker",
  "autoclankerRepo": "../autoclanker",
  "constraints": [
    "Keep incident recall stable.",
    "Retain a reproducible eval command."
  ],
  "defaultIdeasMode": "canonicalize",
  "enabled": true,
  "evalCommand": "python3 examples/targets/parser-quickstart/benchmark.py --era-id \"${PI_AUTOCLANKER_UPSTREAM_ERA_ID}\" --candidate-id \"${PI_AUTOCLANKER_TARGET_CANDIDATE_ID:-cand_c_compiled_context_pair}\"",
  "goal": "Improve parser throughput without trading away alarm context.",
  "sessionRoot": ".autoclanker"
}
